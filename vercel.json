{
  "version": 2,
  "functions": {
    "api/football.js": { "memory": 128, "maxDuration": 10 },
    "api/cricket.js":  { "memory": 128, "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "s-maxage=300, stale-while-revalidate=60" }
      ]
    }
  ]
}
